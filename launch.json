{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Home Planet",
            "type": "process",
            "command": "C:/msys64/ucrt64/bin/gcc.exe",
            "args": [
                "-g",
                "${workspaceFolder}/src/main.c",
                "-o",
                "${workspaceFolder}/bin/HomePlanet.exe",
                "-I", "${workspaceFolder}/src",
                "-I", "C:/raylib/raylib/src",
                "-L", "C:/raylib/raylib/src",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-mconsole",
                "-std=c99",
                "-Wall"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}